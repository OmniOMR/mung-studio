{
    "name": "@mung-studio/mung-studio",
    "version": "1.4.1-dev",
    "private": true,
    "source": [
        "index.html"
    ],
    "browserslist": "> 0.5%, last 2 versions, not dead",
    "scripts": {
        "start": "npm run clean && vite",
        "start-public": "npm run clean && vite --host 0.0.0.0",
        "build": "npm run clean && vite build",
        "clean": "node scripts/clean.js",
        "serve": "vite preview --host 0.0.0.0",
        "lint": "eslint src/**/*.tsx",
        "prettier-check": "prettier src pyodide/*.ts --check",
        "prettier-write": "prettier src pyodide/*.ts --write",
        "postinstall": "node scripts/postinstall.js"
    },
    "pyodide": {
        "mung-path": "pyodide/mung",
        "mung-url": "https://github.com/OmniOMR/mung",
        "mung-commit": "d37ed97"
    },
    "models": {
        "models-path": "models",
        "models-url": "https://github.com/OmniOMR/models",
        "models-tag": "consistent-det-v1.0",
        "models-date": "2026-04-10",
        "models-resolution": 640,
        "models-dpi": 280,
        "onnx-filename": "det-consistent-det.onnx",
        "config-filename": "config-consistent-det.yaml"
    },
    "devDependencies": {
        "@babel/core": "^7.23.3",
        "@babel/eslint-parser": "^7.23.3",
        "@babel/preset-env": "^7.23.3",
        "@babel/preset-react": "^7.23.3",
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.0",
        "@modyfi/vite-plugin-yaml": "^1.1.1",
        "@mui/icons-material": "^6.4.5",
        "@mui/joy": "5.0.0-beta.49",
        "@mui/material": "^6.4.5",
        "@types/archiver": "^7.0.0",
        "@types/d3": "^7.4.3",
        "@types/node": "^22.15.0",
        "@types/react": "^19.0.10",
        "@vitejs/plugin-react": "^4.3.4",
        "archiver": "7.0.1",
        "d3": "^7.9.0",
        "eslint": "^8.54.0",
        "eslint-plugin-react": "^7.34.0",
        "gl-matrix": "^3.4.3",
        "jotai": "^2.12.1",
        "onnxruntime-web": "^1.24.3",
        "prettier": "^3.5.1",
        "pyodide": "^0.27.7",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-router-dom": "^6.23.0",
        "react-scan": "^0.1.3",
        "strongly-typed-events": "^3.0.11",
        "tinykeys": "^3.0.0",
        "vite": "^6.2.5"
    }
}
